{
  "总体架构": "模型输入为光场图像（包含多个视角或子孔径图像），经过特征提取、编码器-解码器结构、双掩模物理模型处理，最终输出深度图。输入光场数据首先转换为EPI格式，通过卷积层和残差块提取特征，结合非朗伯反射物理约束，输出深度估计结果。",
  "模块详情": [
    {
      "模块名": "输入处理层",
      "输入": "光场图像（尺寸：H×W×num_views，num_views=81）",
      "核心操作": "将光场转换为EPI格式并归一化",
      "输出": "EPI特征图（尺寸：H×W×C_in）",
      "关键公式": "EPI转换：EPI(u,v) = I(x(u,v), y(u,v))，其中(x,y)为光场子孔径坐标"
    },
    {
      "模块名": "特征提取模块",
      "输入": "EPI特征图（H×W×C_in）",
      "核心操作": "3层卷积+残差块（kernel_size=3, stride=1, padding=1）",
      "输出": "特征图（H×W×256）",
      "关键公式": "卷积操作：F = Conv(EPI; W_conv) + Residual(F)"
    },
    {
      "模块名": "编码器模块",
      "输入": "特征图（H×W×256）",
      "核心操作": "4个下采样块（stride=2，每层通道翻倍）",
      "输出": "编码特征（H/16×W/16×2048）",
      "关键公式": "下采样：Downsample(F) = MaxPool(Conv(F; W_down))"
    },
    {
      "模块名": "解码器模块",
      "输入": "编码特征（H/16×W/16×2048）",
      "核心操作": "4个上采样块（stride=1/2，跳跃连接）",
      "输出": "解码特征（H×W×256）",
      "关键公式": "上采样：Upsample(F) = ConvTranspose(F; W_up) + SkipConnection"
    },
    {
      "模块名": "双掩模预测头",
      "输入": "解码特征（H×W×256）",
      "核心操作": "分离的Lambertian/Non-Lambertian掩模预测",
      "输出": "深度图（H×W×1）",
      "关键公式": "深度融合：D = M_Lambertian*D_Lambertian + M_NonLambertian*D_NonLambertian"
    }
  ],
  "模块连接": "输入处理层→特征提取模块→编码器模块→解码器模块→双掩模预测头。特征通过跳跃连接从解码器传递到编码器，双掩模头同时预测深度和掩模权重",
  "关键超参数": {
    "学习率": 0.0002,
    "batch_size": 8,
    "num_views": 81,
    "loss_type": "L1",
    "grad_clip": 1.0,
    "warmup_steps": 3,
    "total_steps": 72,
    "scheduler": "cosine_warmup",
    "optimizer": "Adam",
    "activation": "ReLU"
  }
}