# API密钥配置
# 请复制此文件为 .env 并填入您的实际API密钥
# 未配置的密钥默认为空字符串，对应功能将不可用

# ==================== 国内API（优先，无需代理） ====================

# 智谱GLM API密钥（https://open.bigmodel.cn）
ZHIPU_GLM_API_KEY=

# 智谱 Coding Plan API密钥（代码专用，吞吐量更高 https://open.bigmodel.cn/api/coding/paas/v4）
ZHIPU_CODING_API_KEY=

# 智谱 GLM Coding Plan MCP 服务密钥（用于 web-search-prime, web-reader, zread 三个MCP服务增强文献检索）
GLM_CODING_PLAN_API_KEY=

# 阿里云百炼 API密钥（https://dashscope.aliyuncs.com）
ALI_BAILIAN_API_KEY=

# 阿里 Token Plan API密钥（代码专用，吞吐量更高 https://token-plan.cn-beijing.maas.aliyuncs.com）
ALI_TOKEN_PLAN_API_KEY=

# ==================== 国际API（需代理） ====================

# OpenAI API密钥
OPENAI_API_KEY=

# Claude API密钥
CLAUDE_API_KEY=

# ==================== 工具API ====================



